<odoo>

    <record id="change_state_form_wizard" model="ir.ui.view">
        <field name="name">Change State</field>
        <field name="model">change_state</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="property_id"/>
                    <field name="state"/>
                    <field name="reason"/>
                </group>
                <footer>
                    <button name="action_confirm"
                            type="object"
                            string="Confirm"
                            class="btn-primary"
                    />
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"
                    />
                </footer>
            </form>
        </field>
    </record>
    <record id="change_state_action_wizard" model="ir.actions.act_window">
        <field name="name">Change State</field>
        <field name="res_model">change_state</field>
        <field name="target">new</field>
        <field name="view_mode">form</field>
    </record>
</odoo>