<odoo>
    <record id="owner_list_view" model="ir.ui.view">
        <field name="name">Property List</field>
        <field name="model">owner</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="address"/>
            </list>
        </field>
    </record>
    <record id="owner_form_view" model="ir.ui.view">
        <field name="name">Owner</field>
        <field name="model">owner</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                        <group>
                            <field name="property_ids" widget="many2many_tags"/>
                            <field name="address"/>
                        </group>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" widget="mail_thread"/>
                </chatter>
            </form>
        </field>
    </record>
    <record id="owner_action" model="ir.actions.act_window">
        <field name="name">Owner</field>
        <field name="res_model">owner</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="owner_view"
              name="Owner"
              parent="configration_view"
              action="owner_action"
    />
</odoo>