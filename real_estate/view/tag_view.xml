<odoo>
     <record id="tag_list_view" model="ir.ui.view">
        <field name="name">Tag List</field>
        <field name="model">tag</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>
    <record id="tag_form_view" model="ir.ui.view">
        <field name="name">Tag</field>
        <field name="model">tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>
    <record id="tag_action" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">tag</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="tag_view"
              name="Tags"
              parent="configration_view"
              action="tag_action"
    />
</odoo>