<odoo>
    <record id="property_list_view" model="ir.ui.view">
        <field name="name">Property List</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <list class="custom_header" decoration-danger="is_late">
                <field name="name"/>
                <field name="date"/>
                <field name="selling_price"/>
                <field name="expecting_price"/>
                <field name="bedrooms"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="property_search_view" model="ir.ui.view">
        <field name="name">property search</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <search>
                <field name="postcode"/>
                <field name="name"/>
                <filter name="is_garage" string="Garage" domain="[('garage','=','True')]"/>
                <filter name="is_garden" string="Garden" domain="[('garden','=','True')]"/>
                <filter name="group_garden" string="Garden" context="{'group_by':'garden'}"/>
            </search>
        </field>
    </record>
    <record id="property_form_view" model="ir.ui.view">
        <field name="name">Property Form</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                        <widget name="web_ribbon" title="Sold" bg_color="text-bg-success" invisible="state !='sold'"/>

                        <button name="action"
                                type="object"
                                class="btn-primary"
                                string="Action"
                        />
                        <button name="action_draft"
                                type="object"
                                class="btn-primary"
                                string="Set to draft"
                                invisible="state in('draft','closed')"
                        />
                        <button name="action_pending"
                                type="object"
                                class="btn-secondary"
                                string="Pending"
                                invisible="state !='draft'"
                        />
                        <button name="action_sold"
                                type="object"
                                class="btn-success"
                                string="Sold"
                                invisible="state !='pending'"
                        />
                        <field name="state" widget="statusbar" options="{'clickable':1,}"/>
                    </header>
                    <div class="oe_title">
                        <label for="ref"/>
                        <h1>
                            <field name="ref"/>
                        </h1>
                        <label for="name"/>
                        <h2>
                            <field name="name" readonly="state == 'closed'"/>
                        </h2>
                    </div>
                    <group>
                        <group string="information">
                            <field name="postcode" readonly="state == 'closed'"/>
                            <field name="date" readonly="state == 'closed'"/>
                            <field name="expected_selling_date" readonly="state == 'closed'"/>
                            <field name="description" readonly="state == 'closed'"/>
                            <field name="bedrooms" readonly="state == 'closed'"/>
                            <field name="tag_ids" widget="many2many_tags" readonly="state == 'closed'"/>
                            <field name="active"/>
                        </group>
                        <group string="addition info">
                            <field name="expecting_price" readonly="state == 'closed'"/>
                            <field name="selling_price" readonly="state == 'closed'"/>
                            <field name="diff" readonly="state == 'closed'"/>
                            <field name="is_late" readonly="state == 'closed'"/>
                            <field name="owner_id" readonly="state == 'closed'"/>
                            <field name="phone_id" readonly="state == 'closed'"/>
                            <field name="garage" readonly="state == 'closed'"/>
                            <field name="garden" readonly="state == 'closed'"/>
                        </group>
                        <notebook>
                            <page string="Bedrooms">
                                <field name="property_line_ids">
                                    <list editable="bottom">
                                        <field name="description" required="1"/>
                                        <field name="area"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </group>

                </sheet>
                <chatter>
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" widget="mail_thread"/>
                </chatter>
            </form>
        </field>
    </record>
    <!--Server Actions

    <record id="property_closed_server_action" model="ir.actions.server">
        <field name="name">Closed</field>
        <field name="model_id" ref="model_property"/>
        <field name="binding_model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_closed()
        </field>
    </record> -->
    <!-- Server Action wizard-->
    <record id="property_closed_server_action" model="ir.actions.server">
        <field name="name">Change state</field>
        <field name="model_id" ref="model_property"/>
        <field name="binding_model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_open_change_state_wizard()
        </field>
    </record>
    <!-- Automated Actions-->
    <record id="check_selling_date_cron" model="ir.cron">
        <field name="name">Property:Check Selling date</field>
        <field name="model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">model.check_expected_selling_date()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
    <record id="property_actions" model="ir.actions.act_window">
        <field name="name">Property</field>
        <field name="res_model">property</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="property_view"
              name="property"
              parent="properties_menu"
              action="property_actions"
    />
</odoo>