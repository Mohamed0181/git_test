<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        شاشة حجب الاشتراك المنتهي
        تظهر فوق واجهة أودو الكاملة عند إيقاف الاشتراك
        مستوحاة من رسالة Odoo Online عند انتهاء الاشتراك
    -->
    <template id="saas_block_ui_layout" inherit_id="web.layout">
        <xpath expr="//body" position="inside">
            <t t-set="saas_status"
               t-value="request.env['ir.config_parameter'].sudo().get_param('saas.subscription_status', 'active')"/>

            <t t-if="saas_status != 'active'">

                <!-- Overlay يغطي الشاشة كاملة -->
                <div id="saas_block_screen"
                     style="
                        position: fixed;
                        top: 0; left: 0;
                        width: 100vw; height: 100vh;
                        background: rgba(0, 0, 0, 0.82);
                        backdrop-filter: blur(6px);
                        -webkit-backdrop-filter: blur(6px);
                        z-index: 2147483647;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
                     ">

                    <!-- بطاقة الرسالة -->
                    <div style="
                        background: #ffffff;
                        border-radius: 16px;
                        padding: 48px 56px;
                        max-width: 520px;
                        width: 90%;
                        text-align: center;
                        box-shadow: 0 24px 64px rgba(0,0,0,0.45);
                        animation: saas_fadein 0.35s ease-out;
                    ">

                        <!-- أيقونة التحذير -->
                        <div style="
                            width: 72px; height: 72px;
                            background: #fff0f0;
                            border-radius: 50%;
                            display: flex; align-items: center; justify-content: center;
                            margin: 0 auto 24px;
                            font-size: 36px;
                        ">🔒</div>

                        <!-- العنوان -->
                        <h2 style="
                            margin: 0 0 12px;
                            font-size: 22px;
                            font-weight: 700;
                            color: #c0392b;
                        ">تم إيقاف الاشتراك</h2>

                        <!-- خط فاصل -->
                        <div style="
                            width: 48px; height: 3px;
                            background: #e74c3c;
                            border-radius: 2px;
                            margin: 0 auto 20px;
                        "></div>

                        <!-- النص التفصيلي -->
                        <p style="
                            font-size: 15px;
                            color: #555;
                            line-height: 1.7;
                            margin: 0 0 28px;
                        ">
                            عفواً، لقد تم إيقاف هذه القاعدة نظراً لانتهاء فترة الاشتراك
                            أو إيقافها من قِبَل الإدارة.<br/>
                            يرجى التواصل مع مزود الخدمة لتجديد الاشتراك واستعادة صلاحية الدخول.
                        </p>

                        <!-- زر التواصل -->
                        <a href="mailto:support@yourdomain.com"
                           style="
                               display: inline-block;
                               background: #2c7be5;
                               color: #ffffff;
                               text-decoration: none;
                               padding: 13px 32px;
                               border-radius: 8px;
                               font-size: 15px;
                               font-weight: 600;
                               letter-spacing: 0.3px;
                               transition: background 0.2s;
                           ">
                            📧 تواصل مع الدعم الفني
                        </a>

                    </div>
                </div>

                <!-- إخفاء واجهة أودو كاملاً + منع أي تفاعل -->
                <style>
                    .o_web_client,
                    .o_home_menu,
                    .o_action_manager {
                        display: none !important;
                        pointer-events: none !important;
                        visibility: hidden !important;
                    }

                    @keyframes saas_fadein {
                        from { opacity: 0; transform: translateY(-20px); }
                        to   { opacity: 1; transform: translateY(0);     }
                    }
                </style>

            </t>
        </xpath>
    </template>
</odoo>
